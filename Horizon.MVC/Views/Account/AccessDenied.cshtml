@{
    ViewData["Title"] = "Access Denied";
}

<div class="container mt-5 py-5 text-center">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <div class="mb-4">
                <i class="fa-solid fa-shield-halved text-danger" style="font-size: 6rem;"></i>
            </div>
            <h1 class="fw-bold mb-3">Access Denied</h1>
            <p class="lead mb-5 text-muted">
                Oops! It looks like you don't have the required permissions to view this content. 
                This often happens when a <strong>Teacher</strong> tries to enroll in a course or access student-only areas.
            </p>
            <div class="d-flex justify-content-center gap-3">
                <a asp-controller="Courses" asp-action="Index" class="btn btn-outline-secondary btn-lg rounded-pill px-5">
                    <i class="fa-solid fa-house me-2"></i> Home
                </a>
                <a asp-controller="Account" asp-action="Login" class="btn btn-primary btn-lg rounded-pill px-5 shadow-sm">
                    <i class="fa-solid fa-user-circle me-2"></i> Switch Account
                </a>
            </div>
        </div>
    </div>
</div>

@{
    ViewData["Title"] = "Secure Access";
    Layout = "_AuthLayout";
    var returnUrl = ViewData["ReturnUrl"] as string;
}

<div class="row justify-content-center align-items-center min-vh-75">
    <div class="col-md-6 col-lg-5">
        <div class="glass-panel p-5 shadow-lg border-opacity-10 position-relative overflow-hidden">
            <!-- Decorative Element -->
            <div class="position-absolute top-0 end-0 p-4 opacity-10">
                <i class="fa-solid fa-shield-halved fa-6x text-success"></i>
            </div>

            <div class="text-center mb-5 position-relative">
                <span class="badge-academic mb-3 d-inline-block">Institutional Portal</span>
                <h2 class="display-font text-white mb-2" style="font-size: 3.5rem;">Mock Login</h2>
                <p class="text-muted lead">Select your credentials to initialize session</p>
            </div>

            <form asp-action="Login" method="post" class="position-relative">
                <input type="hidden" name="returnUrl" value="@returnUrl" />
                
                <div asp-validation-summary="All" class="text-danger small mb-4"></div>

                <div class="mb-5">
                    <label class="form-label small text-uppercase fw-bold letter-spacing-2 mb-3" style="color: var(--accent-primary);">Security Identifier</label>
                    <div class="input-group">
                        <span class="input-group-text border-0 bg-transparent text-success fs-4 pe-3">
                            <i class="fa-solid fa-fingerprint"></i>
                        </span>
                        <input type="email" name="email" class="form-control border-0 text-white fs-5" 
                               style="background: rgba(255,255,255,0.05); border-radius: 12px; padding: 1.2rem;" 
                               placeholder="identifier@eduplatform" value="testuser@example.com" required />
                    </div>
                </div>
                
                <div class="mb-5">
                    <label class="form-label small text-uppercase fw-bold letter-spacing-2 mb-3" style="color: var(--accent-primary);">Credential Class</label>
                    <div class="row g-4">
                        <div class="col-6">
                            <input type="radio" class="btn-check" name="role" id="roleTeacher" value="Teacher" checked>
                            <label class="btn btn-role-selector w-100 py-4 rounded-4 d-flex flex-column align-items-center gap-3" for="roleTeacher">
                                <div class="icon-box">
                                    <i class="fa-solid fa-chalkboard-user"></i>
                                </div>
                                <span class="small fw-bold">Academic Instructor</span>
                            </label>
                        </div>
                        <div class="col-6">
                            <input type="radio" class="btn-check" name="role" id="roleStudent" value="Student">
                            <label class="btn btn-role-selector w-100 py-4 rounded-4 d-flex flex-column align-items-center gap-3" for="roleStudent">
                                <div class="icon-box">
                                    <i class="fa-solid fa-user-graduate"></i>
                                </div>
                                <span class="small fw-bold">Scholar Student</span>
                            </label>
                        </div>
                    </div>
                </div>

                <div class="d-grid mt-5">
                    <button type="submit" class="btn-premium py-4 shadow-lg fs-6">
                        Authenticate & Enter <i class="fa-solid fa-arrow-right-long ms-3 opacity-50"></i>
                    </button>
                </div>
            </form>

            <div class="mt-5 pt-4 text-center border-top border-secondary border-opacity-10">
                <p class="mb-0 x-small italic text-muted opacity-50">
                    <i class="fa-solid fa-lock me-2"></i> Encrypted Session Persistence Active
                </p>
            </div>
        </div>
    </div>
</div>

<style>
    .min-vh-75 { min-height: 75vh; }
    .letter-spacing-2 { letter-spacing: 2px; }

    .btn-role-selector {
        background: rgba(255,255,255,0.02);
        border: 1px solid rgba(255,255,255,0.05);
        color: var(--text-muted);
        transition: var(--transition-smooth);
    }
    
    .icon-box {
        width: 50px;
        height: 50px;
        background: rgba(255,255,255,0.05);
        border-radius: 12px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 1.5rem;
        transition: var(--transition-smooth);
    }

    .btn-check:checked + .btn-role-selector {
        background: rgba(82, 183, 136, 0.08);
        border-color: var(--accent-primary) !important;
        color: white;
        transform: translateY(-5px);
    }
    
    .btn-check:checked + .btn-role-selector .icon-box {
        background: var(--accent-primary);
        color: var(--text-inverse);
    }

    input::placeholder { color: rgba(255,255,255,0.1) !important; }
</style>

<!DOCTYPE html>
<html class="light" lang="en">
<head>
    <meta charset="utf-8"/>
    <meta content="width=device-width, initial-scale=1.0" name="viewport"/>
    <title>@ViewData["Title"] - The Horizon</title>
    <script src="https://cdn.tailwindcss.com?plugins=forms,container-queries"></script>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=Newsreader:opsz,wght@6-72,400;500;600;700&display=swap" rel="stylesheet"/>
    <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&display=swap" rel="stylesheet"/>
    <style>
        .material-symbols-outlined {
            font-variation-settings: 'FILL' 0, 'wght' 400, 'GRAD' 0, 'opsz' 24;
        }
        body { background-color: #F7F9F6; }
        .dark body { background-color: #0F1714; color: #dfe4de; }
    </style>
    <script id="tailwind-config">
        tailwind.config = {
            darkMode: "class",
            theme: {
                extend: {
                    "colors": {
                        "primary": "#096444",
                        "primary-container": "#2e7d5b",
                        "on-primary": "#ffffff",
                        "surface": "#f2fbff",
                        "on-surface": "#121d21",
                        "on-background": "#121d21"
                    },
                    "fontFamily": {
                        "button": ["Inter"],
                        "display-lg": ["Newsreader"],
                        "headline-sm": ["Newsreader"],
                        "body-lg": ["Inter"],
                        "body-md": ["Inter"]
                    }
                },
            },
        }
    </script>
</head>
<body class="font-body-md text-on-background min-h-screen bg-[#F7F9F6] dark:bg-[#0F1714] selection:bg-[#a4f3ca] selection:text-[#096444]">

@RenderBody()

<script src="~/lib/jquery/dist/jquery.min.js"></script>
@await RenderSectionAsync("Scripts", required: false)

<script>
    // Persist dark mode preference
    const savedTheme = localStorage.getItem('horizon-theme') || 'light';
    document.documentElement.className = savedTheme;
    document.body.style.backgroundColor = savedTheme === 'dark' ? '#0F1714' : '#F7F9F6';
</script>
</body>
</html>

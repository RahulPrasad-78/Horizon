@model Horizon.MVC.Models.BookmarkViewModel

@{
    ViewData["Title"] = "Edit Bookmark";
}

<div class="row justify-content-center">
    <div class="col-md-6">
        <div class="card p-4">
            <h4 class="fw-bold mb-4"><i class="bi bi-pencil-square me-2 text-primary"></i>Edit Bookmark</h4>
            <form method="post">
                <input type="hidden" asp-for="Id" />
                <div class="mb-3">
                    <label asp-for="CourseId" class="form-label fw-semibold">Course ID</label>
                    <input asp-for="CourseId" class="form-control" readonly />
                </div>
                <div class="mb-3">
                    <label asp-for="Category" class="form-label fw-semibold">Category</label>
                    <input asp-for="Category" class="form-control" />
                    <span asp-validation-for="Category" class="text-danger small"></span>
                </div>
                <div class="mb-3">
                    <label asp-for="PersonalNote" class="form-label fw-semibold">Personal Note</label>
                    <textarea asp-for="PersonalNote" class="form-control" rows="3"></textarea>
                </div>
                <div class="d-flex gap-2">
                    <button type="submit" class="btn btn-primary">
                        <i class="bi bi-save me-2"></i>Update
                    </button>
                    <a asp-action="Index" class="btn btn-outline-secondary">Cancel</a>
                </div>
            </form>
        </div>
    </div>
</div>


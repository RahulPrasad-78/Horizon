@model List<int>

@{
    ViewData["Title"] = "Recommendations";
}

<h2 class="fw-bold mb-4"><i class="bi bi-stars me-2 text-primary"></i>Recommended For You</h2>

@if (!Model.Any())
{
    <div class="alert alert-info">
        <i class="bi bi-info-circle me-2"></i>
        No recommendations yet — enroll in some courses and bookmark lessons to get personalized suggestions.
    </div>
}
else
{
    <div class="row g-3">
        @foreach (var courseId in Model)
        {
            <div class="col-md-4">
                <div class="card p-4 text-center">
                    <i class="bi bi-play-circle-fill display-4 text-primary mb-3"></i>
                    <h5 class="fw-bold">Course #@courseId</h5>
                    <p class="text-muted small">Recommended based on your learning activity</p>
                    <a asp-controller="Enrollment" asp-action="Enroll"
                       asp-route-courseId="@courseId"
                       class="btn btn-primary mt-2">
                        <i class="bi bi-plus-circle me-2"></i>Enroll Now
                    </a>
                </div>
            </div>
        }
    </div>
}

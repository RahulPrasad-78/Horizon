@{
    Layout = null;
    ViewData["Title"] = "The Horizon - Elevate Your Learning";
}
<!DOCTYPE html>
<html lang="en" class="scroll-smooth">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"]</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://fonts.googleapis.com/css2?family=Newsreader:ital,opsz,wght@0,6..72,400;0,6..72,500;0,6..72,600;0,6..72,700;0,6..72,800;1,6..72,400;1,6..72,500&family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
    <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:opsz,wght,FILL,GRAD@24,400,0..1,0" rel="stylesheet" />
    <script>
        tailwind.config = {
            darkMode: 'class',
            theme: {
                extend: {
                    fontFamily: {
                        sans: ['Inter', 'sans-serif'],
                        serif: ['Newsreader', 'serif'],
                    },
                    colors: {
                        brand: {
                            50: '#F0F5F2',
                            100: '#E3E8E5',
                            500: '#2E7D5B',
                            600: '#096444',
                            900: '#0F1714',
                        }
                    },
                    animation: {
                        'fade-up': 'fadeUp 0.8s ease forwards',
                        'float': 'float 6s ease-in-out infinite',
                    },
                    keyframes: {
                        fadeUp: {
                            '0%': { opacity: '0', transform: 'translateY(20px)' },
                            '100%': { opacity: '1', transform: 'translateY(0)' },
                        },
                        float: {
                            '0%, 100%': { transform: 'translateY(0)' },
                            '50%': { transform: 'translateY(-20px)' },
                        }
                    }
                }
            }
        }
    </script>
    <style>
        .material-symbols-outlined { font-variation-settings: "FILL" 0, "wght" 400, "GRAD" 0, "opsz" 24; }
        .material-symbols-outlined.filled { font-variation-settings: "FILL" 1, "wght" 400, "GRAD" 0, "opsz" 24; }
        .bg-grid-pattern { background-image: radial-gradient(var(--tw-gradient-stops)); }
    </style>
</head>
<body class="font-sans bg-[#F7F9F6] text-gray-900 selection:bg-[#2E7D5B] selection:text-white overflow-x-hidden">
    
    <!-- Navigation -->
    <nav class="fixed w-full z-50 transition-all duration-300" id="navbar">
        <div class="max-w-7xl mx-auto px-6 lg:px-8">
            <div class="flex items-center justify-between h-20">
                <!-- Logo -->
                <div class="flex-shrink-0 flex items-center gap-3 cursor-pointer" onclick="window.scrollTo(0,0)">
                    <div class="w-10 h-10 bg-[#2E7D5B] rounded-xl flex items-center justify-center text-white shadow-lg shadow-[#2E7D5B]/30">
                        <span class="material-symbols-outlined text-[24px]">school</span>
                    </div>
                    <span class="font-serif text-2xl font-bold tracking-tight text-gray-900">The Horizon</span>
                </div>

                <!-- Desktop Nav -->
                <div class="hidden md:flex items-center gap-6">
                    @if (User.Identity?.IsAuthenticated == true)
                    {
                        <span class="text-sm font-medium text-slate-600">Welcome, @User.Identity.Name!</span>
                        @if (User.IsInRole("Admin"))
                        {
                            <a asp-controller="Admin" asp-action="Dashboard" class="text-sm font-bold text-slate-600 hover:text-[#2E7D5B] transition-colors">Admin</a>
                        }
                        <a href="/Dashboard" class="text-sm font-bold bg-[#2E7D5B] text-white px-5 py-2.5 rounded-lg hover:bg-[#096444] transition-colors shadow-sm">Dashboard</a>
                        <a asp-controller="Auth" asp-action="Logout" class="text-sm font-bold text-rose-600 hover:bg-rose-50 px-4 py-2.5 rounded-lg transition-colors">Logout</a>
                    }
                    else
                    {
                        <a asp-controller="Auth" asp-action="Login" class="text-sm font-bold text-slate-600 hover:text-[#2E7D5B] transition-colors">Log in</a>
                        <a asp-controller="Auth" asp-action="Register" class="text-sm font-bold bg-gray-900 text-white px-5 py-2.5 rounded-lg hover:bg-[#2E7D5B] transition-colors shadow-sm">Get Started</a>
                    }
                </div>
            </div>
        </div>
    </nav>

    <!-- Hero Section -->
    <div class="relative pt-32 pb-20 sm:pt-40 sm:pb-24 lg:pb-32 overflow-hidden min-h-screen flex items-center">
        <!-- Background decorative elements -->
        <div class="absolute inset-0 -z-10 bg-[#F7F9F6] bg-[radial-gradient(#E3E8E5_1px,transparent_1px)] [background-size:24px_24px]"></div>
        <div class="absolute top-0 right-0 -translate-y-12 translate-x-1/3 -z-10 w-[800px] h-[800px] bg-gradient-to-tr from-[#2E7D5B]/20 to-emerald-300/20 rounded-full blur-3xl opacity-50"></div>
        <div class="absolute bottom-0 left-0 translate-y-1/3 -translate-x-1/3 -z-10 w-[600px] h-[600px] bg-gradient-to-tr from-blue-400/10 to-indigo-400/10 rounded-full blur-3xl opacity-50"></div>

        <div class="max-w-7xl mx-auto px-6 lg:px-8 relative">
            <div class="text-center max-w-4xl mx-auto animate-fade-up">
                
                <div class="inline-flex items-center gap-2 px-3 py-1 rounded-full bg-emerald-100 text-emerald-800 text-sm font-bold mb-8 border border-emerald-200 shadow-sm">
                    <span class="flex w-2 h-2 rounded-full bg-emerald-500 animate-pulse"></span>
                    Registration Open for 2026
                </div>

                <h1 class="font-serif text-5xl sm:text-7xl font-bold tracking-tight text-gray-900 mb-8 leading-[1.1]">
                    Master your future with <br />
                    <span class="text-transparent bg-clip-text bg-gradient-to-r from-[#2E7D5B] to-emerald-500">The Horizon</span>
                </h1>
                
                <p class="mt-6 text-lg sm:text-xl leading-relaxed text-slate-600 max-w-2xl mx-auto mb-10">
                    A premier academic platform integrating curated courses, vast digital libraries, and seamless communication to accelerate your learning journey.
                </p>
                
                <div class="flex flex-col sm:flex-row items-center justify-center gap-4">
                    @if (User.Identity?.IsAuthenticated == true)
                    {
                        <a href="/Dashboard" class="w-full sm:w-auto inline-flex justify-center items-center gap-2 rounded-xl bg-[#2E7D5B] px-8 py-4 text-lg font-bold text-white shadow-lg shadow-[#2E7D5B]/30 hover:bg-[#096444] transition-all hover:-translate-y-0.5">
                            Enter Academy <span class="material-symbols-outlined">arrow_forward</span>
                        </a>
                    }
                    else
                    {
                        <a asp-controller="Auth" asp-action="Register" class="w-full sm:w-auto inline-flex justify-center items-center gap-2 rounded-xl bg-[#2E7D5B] px-8 py-4 text-lg font-bold text-white shadow-lg shadow-[#2E7D5B]/30 hover:bg-[#096444] transition-all hover:-translate-y-0.5">
                            Start Learning <span class="material-symbols-outlined">arrow_forward</span>
                        </a>
                        <a asp-controller="Discovery" asp-action="Index" class="w-full sm:w-auto inline-flex justify-center items-center gap-2 rounded-xl bg-white px-8 py-4 text-lg font-bold text-gray-900 shadow-sm border border-gray-200 hover:border-[#2E7D5B] transition-all">
                            Browse Catalog
                        </a>
                    }
                </div>

                <div class="mt-16 pt-8 border-t border-gray-200 flex flex-wrap justify-center gap-x-12 gap-y-6 opacity-70">
                    <div class="flex items-center gap-2 font-bold text-slate-600"><span class="material-symbols-outlined text-[#2E7D5B]">verified</span> 500+ Courses</div>
                    <div class="flex items-center gap-2 font-bold text-slate-600"><span class="material-symbols-outlined text-[#2E7D5B]">menu_book</span> OpenLibrary API</div>
                    <div class="flex items-center gap-2 font-bold text-slate-600"><span class="material-symbols-outlined text-[#2E7D5B]">forum</span> Direct Mentorship</div>
                </div>
            </div>
        </div>
    </div>

    <!-- Features Section -->
    <div class="py-24 bg-white border-y border-gray-100">
        <div class="max-w-7xl mx-auto px-6 lg:px-8">
            <div class="text-center mb-16">
                <h2 class="font-serif text-3xl md:text-4xl font-bold text-gray-900 mb-4">Why choose The Horizon?</h2>
                <p class="text-lg text-slate-500 max-w-2xl mx-auto">We've reimagined the academic portal to give you a frictionless, deeply engaging learning environment.</p>
            </div>
            
            <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
                <div class="bg-[#F0F5F2] rounded-3xl p-8 border border-[#E3E8E5] hover:shadow-lg transition-all hover:-translate-y-1">
                    <div class="w-14 h-14 bg-white rounded-2xl flex items-center justify-center text-[#2E7D5B] shadow-sm mb-6 border border-[#E3E8E5]">
                        <span class="material-symbols-outlined text-3xl">psychology</span>
                    </div>
                    <h3 class="font-serif text-xl font-bold text-gray-900 mb-3">Structured Learning</h3>
                    <p class="text-slate-600 leading-relaxed">Follow meticulously crafted curriculums designed by industry leaders, complete with progressive tracking and XP milestones.</p>
                </div>
                
                <div class="bg-[#F0F5F2] rounded-3xl p-8 border border-[#E3E8E5] hover:shadow-lg transition-all hover:-translate-y-1">
                    <div class="w-14 h-14 bg-white rounded-2xl flex items-center justify-center text-[#2E7D5B] shadow-sm mb-6 border border-[#E3E8E5]">
                        <span class="material-symbols-outlined text-3xl">auto_stories</span>
                    </div>
                    <h3 class="font-serif text-xl font-bold text-gray-900 mb-3">Infinite Library</h3>
                    <p class="text-slate-600 leading-relaxed">Seamless integration with the Open Library API gives you instant access to millions of books, neatly organized and searchable.</p>
                </div>
                
                <div class="bg-[#F0F5F2] rounded-3xl p-8 border border-[#E3E8E5] hover:shadow-lg transition-all hover:-translate-y-1">
                    <div class="w-14 h-14 bg-white rounded-2xl flex items-center justify-center text-[#2E7D5B] shadow-sm mb-6 border border-[#E3E8E5]">
                        <span class="material-symbols-outlined text-3xl">forum</span>
                    </div>
                    <h3 class="font-serif text-xl font-bold text-gray-900 mb-3">Direct Mentorship</h3>
                    <p class="text-slate-600 leading-relaxed">Communicate effortlessly with your professors and peers through our secure, real-time academic chat channels.</p>
                </div>
            </div>
        </div>
    </div>

    <!-- Footer -->
    <footer class="bg-white py-12 border-t border-gray-100">
        <div class="max-w-7xl mx-auto px-6 lg:px-8 text-center">
            <div class="flex items-center justify-center gap-2 mb-4">
                <span class="material-symbols-outlined text-[#2E7D5B]">school</span>
                <span class="font-serif text-xl font-bold text-gray-900">The Horizon</span>
            </div>
            <p class="text-slate-500 text-sm mb-4">Empowering minds through structured digital education.</p>
            <p class="text-slate-400 text-xs">© 2026 The Horizon Learning Platform. All rights reserved.</p>
        </div>
    </footer>

    <script>
        // Navbar blur effect on scroll
        window.addEventListener('scroll', () => {
            const nav = document.getElementById('navbar');
            if (window.scrollY > 20) {
                nav.classList.add('bg-white/80', 'backdrop-blur-md', 'shadow-sm', 'border-b', 'border-gray-100');
            } else {
                nav.classList.remove('bg-white/80', 'backdrop-blur-md', 'shadow-sm', 'border-b', 'border-gray-100');
            }
        });
    </script>
</body>
</html>

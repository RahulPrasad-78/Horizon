@model Horizon.MVC.Models.RegisterViewModel
@{
    ViewData["Title"] = "Register";
    Layout = "_AuthLayout";
}

<div class="min-h-[80vh] flex items-center justify-center py-10">
    <div class="w-full max-w-lg bg-white dark:bg-[#16211D] border border-[#E3E8E5] dark:border-[#23332D] rounded-3xl p-8 sm:p-10 shadow-lg animate-[fadeUp_0.5s_ease_forwards]">
        
        <div class="flex items-center justify-center gap-3 mb-8">
            <div class="w-12 h-12 bg-[#2E7D5B] rounded-xl flex items-center justify-center text-white shadow-md shadow-[#2E7D5B]/30">
                <span class="material-symbols-outlined text-[24px]">school</span>
            </div>
            <span class="font-serif text-2xl font-bold text-gray-900 dark:text-[#E6F1EC]">The Horizon</span>
        </div>

        <div class="text-center mb-8">
            <h2 class="font-serif text-3xl font-bold text-gray-900 dark:text-[#E6F1EC] mb-2">Create Account</h2>
            <p class="text-slate-500 dark:text-[#A7B8B0]">Join our community of lifelong learners</p>
        </div>

        <form asp-action="Register" method="post" class="space-y-5">
            <div asp-validation-summary="ModelOnly" class="bg-rose-50 dark:bg-rose-900/20 text-rose-600 dark:text-rose-400 p-3 rounded-xl text-sm font-bold"></div>
            
            <div>
                <label asp-for="DisplayName" class="block text-sm font-bold text-slate-600 dark:text-[#A7B8B0] uppercase tracking-wider mb-2">Full Name</label>
                <div class="relative">
                    <span class="material-symbols-outlined absolute left-4 top-1/2 -translate-y-1/2 text-slate-400">badge</span>
                    <input asp-for="DisplayName" required 
                           class="w-full bg-[#F7F9F6] dark:bg-[#101411] border-2 border-[#E3E8E5] dark:border-[#23332D] rounded-xl pl-12 pr-4 py-3 text-gray-900 dark:text-[#E6F1EC] font-medium focus:border-[#2E7D5B] focus:ring-0 transition-colors placeholder-slate-400" 
                           placeholder="John Doe" />
                </div>
                <span asp-validation-for="DisplayName" class="text-rose-500 text-xs font-bold mt-1 block"></span>
            </div>

            <div>
                <label asp-for="Email" class="block text-sm font-bold text-slate-600 dark:text-[#A7B8B0] uppercase tracking-wider mb-2">Email Address</label>
                <div class="relative">
                    <span class="material-symbols-outlined absolute left-4 top-1/2 -translate-y-1/2 text-slate-400">mail</span>
                    <input asp-for="Email" required 
                           class="w-full bg-[#F7F9F6] dark:bg-[#101411] border-2 border-[#E3E8E5] dark:border-[#23332D] rounded-xl pl-12 pr-4 py-3 text-gray-900 dark:text-[#E6F1EC] font-medium focus:border-[#2E7D5B] focus:ring-0 transition-colors placeholder-slate-400" 
                           placeholder="name@example.com" />
                </div>
                <span asp-validation-for="Email" class="text-rose-500 text-xs font-bold mt-1 block"></span>
            </div>

            <div class="grid grid-cols-1 sm:grid-cols-2 gap-5">
                <div>
                    <label asp-for="Password" class="block text-sm font-bold text-slate-600 dark:text-[#A7B8B0] uppercase tracking-wider mb-2">Password</label>
                    <div class="relative">
                        <span class="material-symbols-outlined absolute left-4 top-1/2 -translate-y-1/2 text-slate-400">lock</span>
                        <input asp-for="Password" required type="password" 
                               class="w-full bg-[#F7F9F6] dark:bg-[#101411] border-2 border-[#E3E8E5] dark:border-[#23332D] rounded-xl pl-10 pr-4 py-3 text-gray-900 dark:text-[#E6F1EC] font-medium focus:border-[#2E7D5B] focus:ring-0 transition-colors placeholder-slate-400" 
                               placeholder="••••••••" />
                    </div>
                    <span asp-validation-for="Password" class="text-rose-500 text-xs font-bold mt-1 block"></span>
                </div>
                <div>
                    <label asp-for="ConfirmPassword" class="block text-sm font-bold text-slate-600 dark:text-[#A7B8B0] uppercase tracking-wider mb-2">Confirm</label>
                    <div class="relative">
                        <span class="material-symbols-outlined absolute left-4 top-1/2 -translate-y-1/2 text-slate-400">lock_reset</span>
                        <input asp-for="ConfirmPassword" required type="password" 
                               class="w-full bg-[#F7F9F6] dark:bg-[#101411] border-2 border-[#E3E8E5] dark:border-[#23332D] rounded-xl pl-10 pr-4 py-3 text-gray-900 dark:text-[#E6F1EC] font-medium focus:border-[#2E7D5B] focus:ring-0 transition-colors placeholder-slate-400" 
                               placeholder="••••••••" />
                    </div>
                    <span asp-validation-for="ConfirmPassword" class="text-rose-500 text-xs font-bold mt-1 block"></span>
                </div>
            </div>

            <div class="pt-2">
                <label asp-for="Role" class="block text-sm font-bold text-slate-600 dark:text-[#A7B8B0] uppercase tracking-wider mb-2">I am a...</label>
                <div class="relative">
                    <span class="material-symbols-outlined absolute left-4 top-1/2 -translate-y-1/2 text-slate-400">manage_accounts</span>
                    <select asp-for="Role" class="w-full bg-[#F7F9F6] dark:bg-[#101411] border-2 border-[#E3E8E5] dark:border-[#23332D] rounded-xl pl-12 pr-4 py-3 text-gray-900 dark:text-[#E6F1EC] font-medium focus:border-[#2E7D5B] focus:ring-0 transition-colors cursor-pointer appearance-none">
                        <option value="Student">Student</option>
                        <option value="Teacher">Teacher (Instructor)</option>
                    </select>
                    <span class="material-symbols-outlined absolute right-4 top-1/2 -translate-y-1/2 text-slate-400 pointer-events-none">expand_more</span>
                </div>
                <span asp-validation-for="Role" class="text-rose-500 text-xs font-bold mt-1 block"></span>
            </div>

            <div class="pt-4">
                <button type="submit" class="w-full bg-[#2E7D5B] hover:bg-[#096444] text-white py-3.5 rounded-xl font-bold transition-all shadow-sm flex items-center justify-center gap-2">
                    Register Account <span class="material-symbols-outlined text-[20px]">person_add</span>
                </button>
            </div>
        </form>

        <div class="text-center mt-8 pt-6 border-t border-[#E3E8E5] dark:border-[#23332D]">
            <p class="text-slate-500 dark:text-[#A7B8B0] text-sm">
                Already have an account? 
                <a asp-action="Login" class="text-[#2E7D5B] dark:text-[#7DD9AB] font-bold hover:underline">Sign In</a>
            </p>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}

@model IEnumerable<Horizon.MVC.DTOs.CourseReadDTO>

@{
    ViewData["Title"] = "Academic Catalog";
}

<div class="row align-items-end mb-5">
    <div class="col-lg-8">
        <span class="badge-academic mb-3 d-inline-block">Curated Content</span>
        <h1 class="display-font text-white mb-0" style="font-size: 4rem;">Explore <span class="text-gradient">Portfolio</span></h1>
        <p class="text-muted lead mt-3 mb-0">Discover scholarly resources and industrial training modules.</p>
    </div>
    <div class="col-lg-4 text-lg-end mt-4 mt-lg-0">
        <a asp-action="TeacherDashboard" class="btn-outline-premium text-decoration-none">
            <i class="fa-solid fa-graduation-cap me-2"></i> Join Faculty
        </a>
    </div>
</div>

<div class="row g-5">
    @if (!Model.Any())
    {
        <div class="col-12 text-center py-5">
            <div class="glass-panel py-5 border-opacity-10">
                <i class="fa-solid fa-folder-open fa-3x text-muted mb-3 opacity-20"></i>
                <h3 class="display-font text-white">Repository Empty</h3>
                <p class="text-muted">No academic modules have been published yet.</p>
            </div>
        </div>
    }
    else
    {
        @foreach (var item in Model)
        {
            <div class="col-md-6 col-lg-4">
                <div class="premium-card h-100 p-0 overflow-hidden d-flex flex-column border-opacity-10 shadow-lg">
                    <!-- Thumbnail with Overlay -->
                    <div class="position-relative">
                        <img src="@(string.IsNullOrEmpty(item.ThumbnailUrl) ? "/images/course-placeholder.jpg" : item.ThumbnailUrl)" 
                             class="card-img-top" alt="@item.Title" style="height: 240px; object-fit: cover; filter: brightness(0.7) contrast(1.1);"
                             onerror="this.src='https://images.unsplash.com/photo-1501504905252-473c47e087f8?w=800&auto=format&fit=crop&q=80'">
                        
                        <div class="position-absolute top-0 end-0 m-3">
                            <div class="glass-panel px-3 py-1 text-white fw-bold shadow-sm" style="font-size: 1.1rem; border-radius: 8px;">
                                $@item.Price.ToString("N0")
                            </div>
                        </div>

                        @if (!string.IsNullOrEmpty(item.Category))
                        {
                            <div class="position-absolute bottom-0 start-0 m-3">
                                <span class="badge-academic px-3 py-1 shadow-sm" style="background: rgba(0,0,0,0.6); backdrop-filter: blur(4px); border-color: rgba(255,255,255,0.1);">
                                    @item.Category
                                </span>
                            </div>
                        }
                    </div>

                    <div class="p-4 d-flex flex-column flex-grow-1" style="background: linear-gradient(180deg, var(--bg-card) 0%, #05100c 100%);">
                        <div class="d-flex align-items-center mb-3 text-muted x-small fw-bold text-uppercase letter-spacing-1">
                            <span class="me-3"><i class="fa-solid fa-clock-rotate-left me-1 text-success"></i> @item.Duration</span>
                            <span><i class="fa-solid fa-signal me-1 text-success"></i> @item.InstructorId</span>
                        </div>
                        
                        <h4 class="display-font text-white mb-3" style="line-height: 1.3;">@item.Title</h4>
                        <p class="text-muted small flex-grow-1 opacity-75" style="line-height: 1.8;">
                            @(item.Description.Length > 120 ? item.Description.Substring(0, 117) + "..." : item.Description)
                        </p>
                        
                        <div class="mt-4 pt-4 border-top border-secondary border-opacity-10 d-flex justify-content-between align-items-center">
                            <div class="d-flex align-items-center">
                                <div class="icon-box-small me-2">
                                    <i class="fa-solid fa-shield-halved text-success small"></i>
                                </div>
                                <span class="small fw-bold text-muted">SECURE-ID: @item.InstructorId</span>
                            </div>
                            <a asp-action="Details" asp-route-id="@item.Id" class="text-success text-decoration-none fw-bold small letter-spacing-1">
                                VIEW DETAILS <i class="fa-solid fa-arrow-right-long ms-2"></i>
                            </a>
                        </div>
                    </div>
                </div>
            </div>
        }
    }
</div>

<style>
    .icon-box-small {
        width: 24px;
        height: 24px;
        background: rgba(255,255,255,0.05);
        border-radius: 6px;
        display: flex;
        align-items: center;
        justify-content: center;
    }
    .letter-spacing-1 { letter-spacing: 1px; }
</style>

